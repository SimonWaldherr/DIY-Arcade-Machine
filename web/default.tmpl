<script>
(() => {
    const { pathname, search, hash } = window.location;
    if (!pathname.endsWith("/") && !pathname.endsWith("/index.html")) {
        const nextUrl = new URL(`${pathname}/`, window.location.origin);
        nextUrl.search = search;
        nextUrl.hash = hash;
        window.location.replace(nextUrl);
    }

})();
</script>
