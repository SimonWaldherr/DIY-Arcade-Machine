function info_inline(data) {
    document.getElementById("info").innerHTML = data;
}

function info_online(url) {
    fetch(url)
        .then((response) => response.text())
        .then((html) => {
            info_inline(html);
        })
        .catch((error) => {
            console.warn(error);
        });
}

function frame_online(url) {
    window.frames["iframe"].location = url;
}
