<script type="application/javascript">
const DIY_ARCADE_TITLE = "DIY Arcade Machine";
function DIYArcadeSetPageTitle() {
    document.title = DIY_ARCADE_TITLE;
}
DIYArcadeSetPageTitle();

window.DIYArcadeLoaderReady = false;
window.DIYArcadeLoaderFallbackTimer = null;
window.DIYArcadeHideLoader = function() {
    window.DIYArcadeLoaderReady = true;
    if (window.DIYArcadeLoaderFallbackTimer) {
        clearTimeout(window.DIYArcadeLoaderFallbackTimer);
        window.DIYArcadeLoaderFallbackTimer = null;
    }
    const transfer = document.getElementById("transfer");
    if (transfer) {
        transfer.classList.add("loader-hidden");
        transfer.hidden = true;
        transfer.style.display = "none";
    }
};
window.DIYArcadeArmLoaderFallback = function(ms) {
    if (window.DIYArcadeLoaderReady || window.DIYArcadeLoaderFallbackTimer) {
        return;
    }
    window.DIYArcadeLoaderFallbackTimer = setTimeout(() => {
        window.DIYArcadeHideLoader();
    }, ms || 7000);
};
setInterval(() => {
    if (window.DIYArcadeLoaderReady || window.DIYArcadeLoaderFallbackTimer) {
        return;
    }
    const progress = document.getElementById("progress");
    const status = document.getElementById("status");
    if (
        progress &&
        status &&
        Number(progress.value) >= Number(progress.max || 100) &&
        status.innerText.indexOf("Starting arcade engine") !== -1
    ) {
        window.DIYArcadeArmLoaderFallback(7000);
    }
    if (progress && Number(progress.value) >= Number(progress.max || 100)) {
        window.DIYArcadeArmLoaderFallback(2500);
    }
}, 500);
setTimeout(() => {
    window.DIYArcadeHideLoader();
}, 20000);

(function setupIOSTouchControls() {
    const keys = ["up", "down", "left", "right", "x", "space"];
    const state = {};
    const presses = {};
    const activeSources = {};

    keys.forEach((key) => {
        state[key] = false;
        presses[key] = 0;
        activeSources[key] = new Set();
    });
    state.presses = presses;

    window.DIYArcadeTouchInput = state;

    function isMobileTouchDevice() {
        const ua = navigator.userAgent || "";
        const platform = navigator.platform || "";
        const iOS = (
            /iPad|iPhone|iPod/.test(ua) ||
            (platform === "MacIntel" && navigator.maxTouchPoints > 1)
        ) && !window.MSStream;
        const android = /Android/.test(ua);
        const mobileUA = /Mobi|Mobile|Tablet/.test(ua);
        return navigator.maxTouchPoints > 0 && (iOS || android || mobileUA);
    }

    function setKey(key, active, button, source) {
        if (!key || !activeSources[key]) {
            return;
        }
        const inputSource = source || "button:" + key;
        if (active) {
            activeSources[key].add(inputSource);
        } else {
            activeSources[key].delete(inputSource);
        }

        const nextActive = activeSources[key].size > 0;
        if (state[key] === nextActive) {
            if (button) {
                button.classList.toggle("is-active", active);
            }
            return;
        }
        state[key] = nextActive;
        if (nextActive) {
            presses[key] += 1;
        }
        if (button) {
            button.classList.toggle("is-active", active);
        }
    }

    function resetAll() {
        keys.forEach((key) => {
            activeSources[key].clear();
            state[key] = false;
        });
        document.querySelectorAll("[data-touch-key]").forEach((button) => {
            button.classList.remove("is-active");
            if (button._touchIds) {
                button._touchIds.clear();
            }
        });
    }

    function preventGesture(event) {
        event.preventDefault();
    }

    if (!isMobileTouchDevice()) {
        return;
    }

    document.body.classList.add("ios-touch-enabled");
    const controls = document.getElementById("ios-touch-controls");
    if (!controls) {
        return;
    }
    controls.setAttribute("aria-hidden", "false");

    const listenerOptions = { passive: false };
    controls.addEventListener("touchstart", preventGesture, listenerOptions);
    controls.addEventListener("touchend", preventGesture, listenerOptions);
    controls.addEventListener("touchcancel", preventGesture, listenerOptions);
    controls.addEventListener("touchmove", preventGesture, listenerOptions);
    controls.addEventListener("gesturestart", preventGesture, listenerOptions);
    controls.addEventListener("gesturechange", preventGesture, listenerOptions);
    controls.addEventListener("gestureend", preventGesture, listenerOptions);
    controls.addEventListener("contextmenu", preventGesture);

    document.querySelectorAll("[data-touch-key]").forEach((button) => {
        const key = button.dataset.touchKey;
        const source = "button:" + key;
        button._touchIds = new Set();

        button.addEventListener("touchstart", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                button._touchIds.add(touch.identifier);
            }
            setKey(key, true, button, source);
        }, listenerOptions);

        const endTouch = (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                button._touchIds.delete(touch.identifier);
            }
            if (button._touchIds.size === 0) {
                setKey(key, false, button, source);
            }
        };

        button.addEventListener("touchend", endTouch, listenerOptions);
        button.addEventListener("touchcancel", endTouch, listenerOptions);
    });

    const canvas = document.getElementById("canvas");
    const swipeTouches = new Map();
    const swipeTimers = {};
    const swipeThreshold = 18;
    const swipePulseMs = 130;
    const tapMaxDistance = 12;
    const tapMaxMs = 260;

    function pulseKey(key, sourcePrefix, pulseMs) {
        if (!key) {
            return;
        }
        const source = sourcePrefix + ":" + key;
        setKey(key, true, null, source);
        if (swipeTimers[key]) {
            clearTimeout(swipeTimers[key]);
        }
        swipeTimers[key] = setTimeout(() => {
            setKey(key, false, null, source);
            swipeTimers[key] = null;
        }, pulseMs);
    }

    function pulseSwipeKey(key) {
        pulseKey(key, "swipe", swipePulseMs);
    }

    function pulseCanvasTap() {
        pulseKey("space", "canvas-tap", swipePulseMs);
    }

    function endCanvasTouches(event) {
        event.preventDefault();
        for (const touch of event.changedTouches) {
            const start = swipeTouches.get(touch.identifier);
            if (start) {
                const dx = touch.clientX - start.startX;
                const dy = touch.clientY - start.startY;
                if (
                    !start.swiped &&
                    Date.now() - start.startedAt <= tapMaxMs &&
                    Math.max(Math.abs(dx), Math.abs(dy)) <= tapMaxDistance
                ) {
                    pulseCanvasTap();
                }
            }
            swipeTouches.delete(touch.identifier);
        }
    }

    if (canvas) {
        canvas.addEventListener("touchstart", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                swipeTouches.set(touch.identifier, {
                    startX: touch.clientX,
                    startY: touch.clientY,
                    x: touch.clientX,
                    y: touch.clientY,
                    startedAt: Date.now(),
                    swiped: false,
                });
            }
        }, listenerOptions);

        canvas.addEventListener("touchmove", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                const start = swipeTouches.get(touch.identifier);
                if (!start) {
                    continue;
                }
                const dx = touch.clientX - start.x;
                const dy = touch.clientY - start.y;
                if (Math.max(Math.abs(dx), Math.abs(dy)) < swipeThreshold) {
                    continue;
                }
                pulseSwipeKey(Math.abs(dx) > Math.abs(dy)
                    ? (dx < 0 ? "left" : "right")
                    : (dy < 0 ? "up" : "down"));
                swipeTouches.set(touch.identifier, {
                    startX: start.startX,
                    startY: start.startY,
                    x: touch.clientX,
                    y: touch.clientY,
                    startedAt: start.startedAt,
                    swiped: true,
                });
            }
        }, listenerOptions);

        canvas.addEventListener("touchend", endCanvasTouches, listenerOptions);
        canvas.addEventListener("touchcancel", endCanvasTouches, listenerOptions);
    }

    window.addEventListener("blur", resetAll);
    window.addEventListener("pagehide", resetAll);
    document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
            resetAll();
        }
    });
})();

async function custom_onload(debug_hidden) {
    console.log(__FILE__, "custom_onload");
    DIYArcadeSetPageTitle();
    pyconsole.hidden = debug_hidden;
    system.hidden = debug_hidden;
    if (!window.DIYArcadeLoaderReady) {
        transfer.hidden = false;
    }
    info.hidden = debug_hidden;
    box.hidden = debug_hidden;
}

function custom_prerun() {
    console.log(__FILE__, "custom_prerun");
}

function custom_postrun() {
    console.log(__FILE__, "custom_postrun");
    DIYArcadeSetPageTitle();
    window.addEventListener("keydown", function(e) {
        if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].indexOf(e.code) > -1) {
            if (!python.config.debug) {
                e.preventDefault();
            }
        }
    }, false);
}

function debug() {
    python.config.debug = true;
    custom_onload(false);
    Module.PyRun_SimpleString("shell.uptime()");
    window_resize();
}

function info_inline(data) {
    document.getElementById("info").innerHTML = data;
}

function info_online(url) {
    fetch(url)
        .then((response) => response.text())
        .then((html) => {
            info_inline(html);
        })
        .catch((error) => {
            console.warn(error);
        });
}

function frame_online(url) {
    window.frames["iframe"].location = url;
}
