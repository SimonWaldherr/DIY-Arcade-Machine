    Folder  : {{cookiecutter.directory}}
    Authors : {{cookiecutter.authors}}
    SPDX-License-Identifier: {{cookiecutter.spdx}}
""")

WIDTH = {{cookiecutter.width}}
HEIGHT = {{cookiecutter.height}}
REFX = 1980
REFY = 1080

def u(real, ref, v):
    if abs(v) < 0.9999999:
        result = int((float(real) / 100.0) * (v * 1000))
        if v < 0:
            return real - result
        return result
    return int((real / ref) * v)

def ux(*argv):
    acc = 0
    for v in argv:
        acc += u(WIDTH, REFX, v)
    return acc

def uy(*argv):
    acc = 0
    for v in argv:
        acc += u(HEIGHT, REFY, v)
    return acc

async def custom_site():
    import asyncio
    import json
    import os
    import platform
    from pathlib import Path

    import embed
    import pygame

    os.environ.setdefault("SDL_AUDIODRIVER", "dummy")
    platform.document.body.style.background = "#050509"

    def compose():
        pygame.display.update()
        window.chromakey(None, *screen.get_colorkey(), 40)

    pygame.init()
    try:
        pygame.mixer.quit()
    except Exception:
        pass
    pygame.font.init()

    screen = pygame.display.set_mode([ux(.100), uy(.100)], pygame.SRCALPHA, 32)
    screen.set_colorkey((0, 0, 0, 0), pygame.RLEACCEL)
    screen.fill((0, 0, 0, 0))
    compose()

    platform.window.eval(
        "document.getElementById('status').innerText='Starting arcade engine...';"
        "document.getElementById('progress').value=100;"
        "document.getElementById('canvas').style.visibility='visible';"
        "if(window.DIYArcadeArmLoaderFallback){window.DIYArcadeArmLoaderFallback(7000);}"
    )

    apk = "{{cookiecutter.archive}}.apk"
    bundle = "{{cookiecutter.archive}}"
    appdir = Path(f"/data/data/{bundle}")
    appdir.mkdir()

    cfg = {
        "io": "url",
        "type": "mount",
        "mount": {
            "point": appdir.as_posix(),
            "path": "/",
        },
        "path": f"/ => {appdir.as_posix()}",
    }

    track = platform.window.MM.prepare(apk, json.dumps(cfg))
    marginx = ux(.020)
    marginy = uy(.045)

    def pg_bar(pos):
        total = track.len or 10
        slot = ux(.060) / total
        pygame.draw.rect(screen, (10, 10, 10), (marginx - ux(10), marginy - uy(10), (total * slot) + ux(20), uy(110)))
        pygame.draw.rect(screen, (0, 255, 0), (marginx, marginy, pos * slot, uy(90)))

    while not track.ready:
        pg_bar(track.pos)
        compose()
        await asyncio.sleep(.1)

    pg_bar(track.len)
    compose()

    platform.run_main(PyConfig, loaderhome=appdir / "assets", loadermain=None)

    while embed.counter() < 0:
        await asyncio.sleep(.1)

    main = appdir / "assets" / "main.py"
    await TopLevel_async_handler.start_toplevel(platform.shell, console=window.python.config.debug)
    __import__(__name__).__file__ = str(main)

    fnt = pygame.sysfont.SysFont("freesans", uy(80))

    def ui_callback(pkg, error=None):
        if error:
            prompt = fnt.render(f"{error}", True, "black")
        else:
            prompt = fnt.render(f"Setting [{pkg}] up", True, "black")
        pg_bar(track.len)
        screen.blit(prompt, (marginx + ux(80), marginy - uy(10)))
        compose()

    if False and not platform.window.MM.UME:
        prompt = fnt.render("Ready to start !", True, "blue")
        pg_bar(track.len)
        screen.blit(prompt, (marginx + ux(80), marginy - uy(10)))
        compose()
        print("* Waiting for media user engagement : please click/touch page *")
        while not platform.window.MM.UME:
            await asyncio.sleep(.1)

    screen.fill((0, 0, 0, 0))
    pygame.display.flip()

    async def local_only_preload(cls, code, callback=None, loaderhome=".", hint=""):
        import os
        import sys

        if loaderhome != ".":
            os.chdir(loaderhome)
        if loaderhome not in sys.path:
            sys.path.append(loaderhome)
        PyConfig.imports_ready = True
        return True

    TopLevel_async_handler.preload_code = classmethod(local_only_preload)

    await shell.runpy(main, callback=ui_callback)

import asyncio
asyncio.run(custom_site())

