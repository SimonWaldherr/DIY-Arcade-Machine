<script type="application/javascript">
const DIY_ARCADE_TITLE = "DIY Arcade Machine";
const DIY_ARCADE_TRANSLATIONS = {
    en: {
        actionControls: "Action controls",
        arrowDown: "Arrow Down",
        arrowLeft: "Arrow Left",
        arrowRight: "Arrow Right",
        arrowUp: "Arrow Up",
        backCancel: "Back or cancel",
        canvasDescription: "Interactive arcade game canvas. Use arrow keys to move, Space or Z for the primary action, and X or Escape for back or cancel.",
        canvasLabel: "DIY Arcade Machine game canvas",
        directionalControls: "Directional controls",
        githubLabel: "Open DIY Arcade Machine on GitHub",
        githubText: "GitHub Repo",
        loaderSubtitle: "Loading WebAssembly arcade...",
        loadingProgress: "Loading progress",
        primaryAction: "Primary action",
        spaceButton: "A",
        statusDownloading: "Downloading...",
        soundToggleOff: "Enable arcade sounds",
        soundToggleOn: "Disable arcade sounds",
    },
    de: {
        actionControls: "Aktionstasten",
        arrowDown: "Pfeil nach unten",
        arrowLeft: "Pfeil nach links",
        arrowRight: "Pfeil nach rechts",
        arrowUp: "Pfeil nach oben",
        backCancel: "Zurueck oder abbrechen",
        canvasDescription: "Interaktive Arcade-Spielflaeche. Bewege dich mit den Pfeiltasten, nutze Leertaste oder Z fuer die Hauptaktion und X oder Escape fuer Zurueck oder Abbrechen.",
        canvasLabel: "DIY Arcade Machine Spielflaeche",
        directionalControls: "Richtungssteuerung",
        githubLabel: "DIY Arcade Machine auf GitHub oeffnen",
        githubText: "GitHub Repo",
        loaderSubtitle: "WebAssembly-Arcade wird geladen...",
        loadingProgress: "Ladefortschritt",
        primaryAction: "Hauptaktion",
        spaceButton: "A",
        statusDownloading: "Wird heruntergeladen...",
        soundToggleOff: "Arcade-Sounds einschalten",
        soundToggleOn: "Arcade-Sounds ausschalten",
    },
};

function DIYArcadeSetPageTitle() {
    document.title = DIY_ARCADE_TITLE;
}

function DIYArcadeLocale() {
    const language = (navigator.language || "en").toLowerCase();
    return language.startsWith("de") ? "de" : "en";
}

function DIYArcadeApplyI18n() {
    const locale = DIYArcadeLocale();
    const messages = DIY_ARCADE_TRANSLATIONS[locale] || DIY_ARCADE_TRANSLATIONS.en;
    document.documentElement.lang = locale;
    document.documentElement.dir = "ltr";
    document.querySelectorAll("[data-i18n]").forEach((element) => {
        const message = messages[element.dataset.i18n];
        if (message) {
            element.textContent = message;
        }
    });
    document.querySelectorAll("[data-i18n-aria-label]").forEach((element) => {
        const message = messages[element.dataset.i18nAriaLabel];
        if (message) {
            element.setAttribute("aria-label", message);
        }
    });
}

DIYArcadeSetPageTitle();
DIYArcadeApplyI18n();

function DIYArcadeIsIOSFullscreenVariant() {
    const params = new URLSearchParams(window.location.search || "");
    const pathParts = (window.location.pathname || "").split("/").filter(Boolean);
    return params.has("ios") || params.has("fullscreen") || pathParts.indexOf("ios") !== -1;
}

(function setupArcadeSound() {
    const storageKey = "DIYArcadeSoundEnabled";
    const button = document.getElementById("sound-toggle");
    const AudioContextCtor = window.AudioContext || window.webkitAudioContext;
    let audioContext = null;
    let enabled = false;
    try {
        enabled = window.localStorage.getItem(storageKey) === "1";
    } catch (_error) {
        enabled = false;
    }

    function currentMessages() {
        return DIY_ARCADE_TRANSLATIONS[DIYArcadeLocale()] || DIY_ARCADE_TRANSLATIONS.en;
    }

    function updateButton() {
        if (!button) {
            return;
        }
        const messages = currentMessages();
        button.classList.toggle("is-on", enabled);
        button.textContent = enabled ? "♫" : "♪";
        button.setAttribute("aria-label", enabled ? messages.soundToggleOn : messages.soundToggleOff);
        button.setAttribute("title", enabled ? messages.soundToggleOn : messages.soundToggleOff);
    }

    function ensureAudioContext() {
        if (!AudioContextCtor) {
            return null;
        }
        if (!audioContext) {
            audioContext = new AudioContextCtor();
        }
        if (audioContext.state === "suspended") {
            audioContext.resume().catch(() => {});
        }
        return audioContext;
    }

    function tone(freq, duration, type, delay, gainValue) {
        const ctx = ensureAudioContext();
        if (!ctx) {
            return;
        }
        const start = ctx.currentTime + (delay || 0);
        const length = duration || 0.055;
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = type || "square";
        osc.frequency.setValueAtTime(freq, start);
        gain.gain.setValueAtTime(0.0001, start);
        gain.gain.exponentialRampToValueAtTime(gainValue || 0.030, start + 0.006);
        gain.gain.exponentialRampToValueAtTime(0.0001, start + length);
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.start(start);
        osc.stop(start + length + 0.015);
    }

    function play(kind, toneIndex) {
        if (!enabled || document.hidden) {
            return;
        }
        const t = Number(toneIndex || 0);
        const base = 180 + ((t % 11) * 18);
        switch (kind) {
            case "select":
                tone(440 + t * 5, 0.030, "square", 0, 0.026);
                break;
            case "start":
                tone(220 + (t % 4) * 35, 0.045, "triangle", 0, 0.024);
                tone(330 + (t % 5) * 28, 0.060, "square", 0.040, 0.024);
                break;
            case "bounce":
                tone(260 + (t % 5) * 44, 0.034, "square", 0, 0.024);
                break;
            case "coin":
                tone(640 + (t % 3) * 70, 0.040, "square", 0, 0.030);
                tone(960 + (t % 3) * 80, 0.055, "square", 0.045, 0.026);
                break;
            case "zap":
                tone(190, 0.065, "sawtooth", 0, 0.022);
                break;
            case "ping":
                tone(base + 520, 0.050, "sine", 0, 0.020);
                break;
            default:
                tone(360, 0.045, "square", 0, 0.022);
                break;
        }
    }

    window.DIYArcadeSound = play;
    window.DIYArcadeSetSoundEnabled = function(nextEnabled) {
        enabled = Boolean(nextEnabled);
        try {
            window.localStorage.setItem(storageKey, enabled ? "1" : "0");
        } catch (_error) {}
        updateButton();
        if (enabled) {
            ensureAudioContext();
            tone(520, 0.030, "square", 0, 0.022);
        }
    };

    if (button) {
        button.addEventListener("click", () => {
            window.DIYArcadeSetSoundEnabled(!enabled);
        });
    }

    document.addEventListener("pointerdown", () => {
        if (enabled) {
            ensureAudioContext();
        }
    }, { passive: true, capture: true });
    document.addEventListener("keydown", () => {
        if (enabled) {
            ensureAudioContext();
        }
    }, { passive: true, capture: true });
    updateButton();
})();

window.DIYArcadeLoaderReady = false;
window.DIYArcadeLoaderFallbackTimer = null;
window.DIYArcadeHideLoader = function() {
    window.DIYArcadeLoaderReady = true;
    if (window.DIYArcadeLoaderFallbackTimer) {
        clearTimeout(window.DIYArcadeLoaderFallbackTimer);
        window.DIYArcadeLoaderFallbackTimer = null;
    }
    const transfer = document.getElementById("transfer");
    if (transfer) {
        transfer.setAttribute("aria-busy", "false");
        transfer.classList.add("loader-hidden");
        transfer.hidden = true;
        transfer.style.display = "none";
    }
};
window.DIYArcadeArmLoaderFallback = function(ms) {
    if (window.DIYArcadeLoaderReady || window.DIYArcadeLoaderFallbackTimer) {
        return;
    }
    window.DIYArcadeLoaderFallbackTimer = setTimeout(() => {
        window.DIYArcadeHideLoader();
    }, ms || 7000);
};
setInterval(() => {
    if (window.DIYArcadeLoaderReady || window.DIYArcadeLoaderFallbackTimer) {
        return;
    }
    const progress = document.getElementById("progress");
    const status = document.getElementById("status");
    if (
        progress &&
        status &&
        Number(progress.value) >= Number(progress.max || 100) &&
        status.innerText.indexOf("Starting arcade engine") !== -1
    ) {
        window.DIYArcadeArmLoaderFallback(7000);
    }
    if (progress && Number(progress.value) >= Number(progress.max || 100)) {
        window.DIYArcadeArmLoaderFallback(2500);
    }
}, 500);
setTimeout(() => {
    window.DIYArcadeHideLoader();
}, 20000);

(function setupIOSTouchControls() {
    const keys = ["up", "down", "left", "right", "x", "space"];
    const state = {};
    const presses = {};
    const activeSources = {};
    const iosFullscreenVariant = DIYArcadeIsIOSFullscreenVariant();

    keys.forEach((key) => {
        state[key] = false;
        presses[key] = 0;
        activeSources[key] = new Set();
    });
    state.presses = presses;

    window.DIYArcadeTouchInput = state;

    function isMobileTouchDevice() {
        const ua = navigator.userAgent || "";
        const platform = navigator.platform || "";
        const iOS = (
            /iPad|iPhone|iPod/.test(ua) ||
            (platform === "MacIntel" && navigator.maxTouchPoints > 1)
        ) && !window.MSStream;
        const android = /Android/.test(ua);
        const mobileUA = /Mobi|Mobile|Tablet/.test(ua);
        return navigator.maxTouchPoints > 0 && (iOS || android || mobileUA);
    }

    function setKey(key, active, button, source) {
        if (!key || !activeSources[key]) {
            return;
        }
        const inputSource = source || "button:" + key;
        if (active) {
            activeSources[key].add(inputSource);
        } else {
            activeSources[key].delete(inputSource);
        }

        const nextActive = activeSources[key].size > 0;
        if (state[key] === nextActive) {
            if (button) {
                button.classList.toggle("is-active", active);
            }
            return;
        }
        state[key] = nextActive;
        if (nextActive) {
            presses[key] += 1;
        }
        if (button) {
            button.classList.toggle("is-active", active);
        }
    }

    function resetAll() {
        keys.forEach((key) => {
            activeSources[key].clear();
            state[key] = false;
        });
        document.querySelectorAll("[data-touch-key]").forEach((button) => {
            button.classList.remove("is-active");
            if (button._touchIds) {
                button._touchIds.clear();
            }
            if (button._pointerIds) {
                button._pointerIds.clear();
            }
        });
    }

    function preventGesture(event) {
        event.preventDefault();
    }

    function pulseHaptic() {
        try {
            if (navigator.vibrate) {
                navigator.vibrate(8);
            }
        } catch (_error) {}
    }

    async function requestWakeLock() {
        try {
            if (!("wakeLock" in navigator) || document.hidden) {
                return;
            }
            window.DIYArcadeWakeLock = await navigator.wakeLock.request("screen");
        } catch (_error) {}
    }

    if (!iosFullscreenVariant && !isMobileTouchDevice()) {
        return;
    }

    document.body.classList.add("ios-touch-enabled");
    if (iosFullscreenVariant) {
        document.body.classList.add("ios-fullscreen-variant");
    }
    const controls = document.getElementById("ios-touch-controls");
    if (!controls) {
        return;
    }
    controls.setAttribute("aria-hidden", "false");

    const listenerOptions = { passive: false };
    controls.addEventListener("touchstart", preventGesture, listenerOptions);
    controls.addEventListener("touchend", preventGesture, listenerOptions);
    controls.addEventListener("touchcancel", preventGesture, listenerOptions);
    controls.addEventListener("touchmove", preventGesture, listenerOptions);
    controls.addEventListener("gesturestart", preventGesture, listenerOptions);
    controls.addEventListener("gesturechange", preventGesture, listenerOptions);
    controls.addEventListener("gestureend", preventGesture, listenerOptions);
    controls.addEventListener("contextmenu", preventGesture);

    document.querySelectorAll("[data-touch-key]").forEach((button) => {
        const key = button.dataset.touchKey;
        const source = "button:" + key;
        button._touchIds = new Set();
        button._pointerIds = new Set();

        const beginButtonPress = () => {
            setKey(key, true, button, source);
            pulseHaptic();
            requestWakeLock();
        };
        const endButtonPress = () => {
            if (button._touchIds.size === 0 && button._pointerIds.size === 0) {
                setKey(key, false, button, source);
            }
        };

        if (window.PointerEvent) {
            button.addEventListener("pointerdown", (event) => {
                event.preventDefault();
                button._pointerIds.add(event.pointerId);
                try {
                    button.setPointerCapture(event.pointerId);
                } catch (_error) {}
                beginButtonPress();
            }, listenerOptions);

            const endPointer = (event) => {
                event.preventDefault();
                button._pointerIds.delete(event.pointerId);
                endButtonPress();
            };

            button.addEventListener("pointerup", endPointer, listenerOptions);
            button.addEventListener("pointercancel", endPointer, listenerOptions);
            button.addEventListener("lostpointercapture", endPointer, listenerOptions);
        }

        button.addEventListener("touchstart", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                button._touchIds.add(touch.identifier);
            }
            beginButtonPress();
        }, listenerOptions);

        const endTouch = (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                button._touchIds.delete(touch.identifier);
            }
            endButtonPress();
        };

        button.addEventListener("touchend", endTouch, listenerOptions);
        button.addEventListener("touchcancel", endTouch, listenerOptions);
    });

    const canvas = document.getElementById("canvas");
    const swipeTouches = new Map();
    const swipeTimers = {};
    const swipeThreshold = 18;
    const swipePulseMs = 130;
    const tapMaxDistance = 12;
    const tapMaxMs = 260;

    function pulseKey(key, sourcePrefix, pulseMs) {
        if (!key) {
            return;
        }
        const source = sourcePrefix + ":" + key;
        setKey(key, true, null, source);
        if (swipeTimers[key]) {
            clearTimeout(swipeTimers[key]);
        }
        swipeTimers[key] = setTimeout(() => {
            setKey(key, false, null, source);
            swipeTimers[key] = null;
        }, pulseMs);
    }

    function pulseSwipeKey(key) {
        pulseKey(key, "swipe", swipePulseMs);
    }

    function pulseCanvasTap() {
        pulseKey("space", "canvas-tap", swipePulseMs);
    }

    function endCanvasTouches(event) {
        event.preventDefault();
        for (const touch of event.changedTouches) {
            const start = swipeTouches.get(touch.identifier);
            if (start) {
                const dx = touch.clientX - start.startX;
                const dy = touch.clientY - start.startY;
                if (
                    !start.swiped &&
                    Date.now() - start.startedAt <= tapMaxMs &&
                    Math.max(Math.abs(dx), Math.abs(dy)) <= tapMaxDistance
                ) {
                    pulseCanvasTap();
                }
            }
            swipeTouches.delete(touch.identifier);
        }
    }

    if (canvas) {
        canvas.addEventListener("touchstart", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                swipeTouches.set(touch.identifier, {
                    startX: touch.clientX,
                    startY: touch.clientY,
                    x: touch.clientX,
                    y: touch.clientY,
                    startedAt: Date.now(),
                    swiped: false,
                });
            }
        }, listenerOptions);

        canvas.addEventListener("touchmove", (event) => {
            event.preventDefault();
            for (const touch of event.changedTouches) {
                const start = swipeTouches.get(touch.identifier);
                if (!start) {
                    continue;
                }
                const dx = touch.clientX - start.x;
                const dy = touch.clientY - start.y;
                if (Math.max(Math.abs(dx), Math.abs(dy)) < swipeThreshold) {
                    continue;
                }
                pulseSwipeKey(Math.abs(dx) > Math.abs(dy)
                    ? (dx < 0 ? "left" : "right")
                    : (dy < 0 ? "up" : "down"));
                swipeTouches.set(touch.identifier, {
                    startX: start.startX,
                    startY: start.startY,
                    x: touch.clientX,
                    y: touch.clientY,
                    startedAt: start.startedAt,
                    swiped: true,
                });
            }
        }, listenerOptions);

        canvas.addEventListener("touchend", endCanvasTouches, listenerOptions);
        canvas.addEventListener("touchcancel", endCanvasTouches, listenerOptions);
    }

    window.addEventListener("blur", resetAll);
    window.addEventListener("pagehide", resetAll);
    document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
            resetAll();
        }
    });
})();

async function custom_onload(debug_hidden) {
    console.log(__FILE__, "custom_onload");
    DIYArcadeSetPageTitle();
    pyconsole.hidden = debug_hidden;
    system.hidden = debug_hidden;
    if (!window.DIYArcadeLoaderReady) {
        transfer.hidden = false;
    }
    info.hidden = debug_hidden;
    box.hidden = debug_hidden;
}

function custom_prerun() {
    console.log(__FILE__, "custom_prerun");
}

function custom_postrun() {
    console.log(__FILE__, "custom_postrun");
    DIYArcadeSetPageTitle();
    window.addEventListener("keydown", function(e) {
        if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].indexOf(e.code) > -1) {
            if (!python.config.debug) {
                e.preventDefault();
            }
        }
    }, false);
}

function debug() {
    python.config.debug = true;
    custom_onload(false);
    Module.PyRun_SimpleString("shell.uptime()");
    window_resize();
}

function info_inline(data) {
    document.getElementById("info").innerHTML = data;
}

function info_online(url) {
    fetch(url)
        .then((response) => response.text())
        .then((html) => {
            info_inline(html);
        })
        .catch((error) => {
            console.warn(error);
        });
}

function frame_online(url) {
    window.frames["iframe"].location = url;
}
</script>
</body>
</html>
